{
  "name": "cryptoqr-tool",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "sync:crypto-icons": "node scripts/sync-crypto-icons.mjs",
    "indexnow:publish": "node scripts/publish-indexnow.mjs",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:unit": "vitest run src/lib/liveData.test.ts src/lib/networks.test.ts src/lib/visibleSearch.test.ts src/lib/verification.test.ts src/lib/qrStyle.test.ts src/lib/storage.test.ts src/lib/server/qrApi.test.ts",
    "test:component": "vitest run src/lib/components/QrPreview.test.svelte.ts src/lib/components/StyleEditor.test.svelte.ts",
    "test:e2e:smoke": "playwright test",
    "test:ci": "bun run check && bun run test && bun run build && bun run test:e2e:smoke",
    "test:release": "bun run test:ci && lhci autorun",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sveltejs/kit": "^2.22.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "clsx": "^2.1.1",
    "lucide-svelte": "^0.468.0",
    "qr-code-styling": "^1.9.2",
    "qrcode": "^1.5.4",
    "svelte": "^5.0.0",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.54.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/adapter-static": "^3.0.6",
    "@tailwindcss/forms": "^0.5.9",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.2.4",
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.6",
    "autoprefixer": "^10.4.20",
    "cryptocurrency-icons": "0.18.1",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "svelte-check": "^4.1.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
